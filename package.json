{
  "name": "playwright-solstice-showcase",
  "version": "1.0.0",
  "description": "Practical SDET Playwright showcase against app.solstice.finance public flows and mocked-wallet scenarios.",
  "private": true,
  "scripts": {
    "test": "playwright test",
    "test:fast": "playwright test --workers=75%",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:report": "playwright show-report",
    "test:public:chromium": "playwright test --project=public-chromium",
    "test:public:fast": "playwright test --project=public-chromium --project=api-smoke --workers=75%",
    "test:public:shard": "playwright test --project=public-chromium",
    "test:public": "playwright test --project=public-chromium --project=public-firefox --project=public-webkit --project=public-mobile-chromium --project=api-smoke",
    "test:wallet-mock": "playwright test --grep @wallet-mock",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "playwright",
    "typescript",
    "e2e",
    "sdet",
    "qa-automation"
  ],
  "author": "dusanat",
  "license": "ISC",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
